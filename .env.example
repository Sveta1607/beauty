# Скопируйте в файл .env (не коммитьте .env). При запуске «node server/index.js» переменные подхватываются через dotenv.

# Порт API (по умолчанию 8787; в Docker/Amvera обычно 80)
PORT=8787

# Продакшен: отдавать статику из dist тем же процессом, что и API
# NODE_ENV=production

# Явно включить раздачу dist без NODE_ENV=production (локальная проверка одного процесса)
# SERVE_STATIC=1

# Дополнительные origin для CORS через запятую (домен сайта в проде)
# CORS_ORIGINS=https://example.com,https://www.example.com

# Amvera Cloud: том Data монтируется в /data (задаётся в amvera.yaml persistenceMount)
# PERSISTENT_DATA_DIR=/data

# Куда слать письма с формы «Оставить заявку»
# LEADS_INBOX_EMAIL=ваш@yandex.ru

# Яндекс: пароль приложения — https://yandex.ru/support/id/authorization/app-passwords.html
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=465
# Если 465 не проходит на хостинге, попробуйте: SMTP_PORT=587
# SMTP_USER=ваш@yandex.ru
# SMTP_PASS=пароль_приложения_без_пробелов

# Подробный лог SMTP в консоль (только для отладки)
# SMTP_DEBUG=1
