# Порт API (по умолчанию 8787)
PORT=8787

# Продакшен: отдавать статику из dist тем же процессом, что и API
NODE_ENV=production

# Явно включить раздачу dist без NODE_ENV=production (локальная проверка одного процесса)
# SERVE_STATIC=1

# Дополнительные origin для CORS через запятую (домен сайта в проде)
# CORS_ORIGINS=https://example.com,https://www.example.com
